NODE_ENV=production
APP_NAME=Nano Banana Pro

# 新用户注册送点数
# 如果你不想送体验额度，保持 0 即可
DEFAULT_SIGNUP_POINTS=0

# 管理员邮箱
# 第一个注册账号会自动成为 super_admin
# 这里填写的邮箱会自动拥有 admin 权限
ADMIN_EMAILS=admin@example.com,ops@example.com

# MySQL
# 当前 docker-compose.yml 会自动连接 mysql 容器
# 所以这里只需要填写数据库密码、库名即可
MYSQL_URL=
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=请替换成强密码_至少16位
MYSQL_DATABASE=nano_banana_pro
MYSQL_CONNECTION_LIMIT=10

# 内置图片线路 Key
# 请替换成你自己的真实线路 Key
IMAGE_ROUTE_DEFAULT_KEY=请替换成你的默认线路Key
IMAGE_ROUTE_NANO_BANANA_PRO_LINE1_KEY=请替换成你的Line1_Key
IMAGE_ROUTE_NANO_BANANA_PRO_LINE2_KEY=请替换成你的Line2_Key
IMAGE_ROUTE_NANO_BANANA_PRO_LINE3_KEY=请替换成你的Line3_Key

# 如果你后续在后台新增 line4 / line5 / line6，
# 并且线路配置里填写了 apiKeyEnv，
# 现在只需要在 .env 里继续新增对应变量即可，
# docker-compose 会自动把整份 .env 透传进 app 容器。
# 例如：
# IMAGE_ROUTE_NANO_BANANA_PRO_LINE4_KEY=请替换成你的Line4_Key

# 邮箱验证码 / 忘记密码
# 推荐直接使用 Resend SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_请替换成你的Resend_API_Key
SMTP_FROM=Nano Banana Pro <noreply@yourdomain.com>

# 兼容旧用户填写的可选 API Key
# 不是必填，不需要就留空
GEMINI_API_KEY=

# 服务端应急管理员 Key
# 前端不会直接使用，仅用于极端情况下的服务端管理操作
BILLING_ADMIN_API_KEY=请替换成一串超长随机字符串
ANNOUNCEMENT_ADMIN_API_KEY=请替换成另一串超长随机字符串

# 说明：
# 1. 这个文件上线时请复制为 .env
# 2. 不要把真实 .env 上传到公开仓库
# 3. 宝塔反向代理目标请指向：http://127.0.0.1:3325
