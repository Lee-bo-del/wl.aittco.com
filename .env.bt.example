NODE_ENV=production
APP_NAME=Nano Banana Pro
PORT=3355

# New user signup bonus points. Keep 0 if you do not want a free trial.
DEFAULT_SIGNUP_POINTS=0

# The first registered account becomes super_admin automatically.
# Emails listed here are also granted admin access.
ADMIN_EMAILS=admin@example.com,ops@example.com

# MySQL
# docker-compose connects the app to the mysql service automatically.
# MYSQL_HOST_PORT is only the host-side bind port used by Docker.
MYSQL_URL=
MYSQL_HOST_PORT=3308
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=replace_with_a_strong_password_at_least_16_chars
MYSQL_DATABASE=nano_banana_pro
MYSQL_CONNECTION_LIMIT=10

# Built-in image route keys
IMAGE_ROUTE_DEFAULT_KEY=replace_with_your_default_route_key
IMAGE_ROUTE_NANO_BANANA_PRO_LINE1_KEY=replace_with_your_line1_key
IMAGE_ROUTE_NANO_BANANA_PRO_LINE2_KEY=replace_with_your_line2_key
IMAGE_ROUTE_NANO_BANANA_PRO_LINE3_KEY=replace_with_your_line3_key

# If you later add line4 / line5 / line6 in the admin panel and fill apiKeyEnv,
# just keep adding the matching variables here.
# docker-compose now passes the whole .env file into the app container automatically.
# Example:
# IMAGE_ROUTE_NANO_BANANA_PRO_LINE4_KEY=replace_with_your_line4_key

# Email verification / forgot password
# Recommended: Resend SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_replace_with_your_resend_api_key
SMTP_FROM=Nano Banana Pro <noreply@yourdomain.com>

# Optional user-provided API key
GEMINI_API_KEY=

# Emergency server-side admin keys
BILLING_ADMIN_API_KEY=replace_with_a_long_random_string
ANNOUNCEMENT_ADMIN_API_KEY=replace_with_another_long_random_string

# Notes:
# 1. Copy this file to .env on the server.
# 2. Never commit your real .env to a public repository.
# 3. BaoTa reverse proxy target: http://127.0.0.1:3355
